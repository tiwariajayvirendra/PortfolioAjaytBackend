<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="/socket.io/socket.io.js"></script>
</head>
<body>
    <% const totalDonations = donations.reduce((acc, curr) => acc + Number(curr.amount), 0); %>

    <div class="min-h-screen bg-gray-100 flex flex-col md:flex-row font-sans">
        <!-- Sidebar -->
        <aside class="bg-white w-full md:w-72 p-6 flex flex-col shadow-xl z-10">
            <h2 class="text-2xl font-extrabold mb-10 text-purple-800 tracking-tight">Admin Panel</h2>
            <nav class="flex-1 space-y-3">
                <button
                    id="messages-tab-btn"
                    class="w-full text-left py-3 px-5 rounded-xl font-medium transition-all duration-200 flex items-center gap-3 bg-purple-100 text-purple-700 shadow-inner"
                >
                    <span>📨</span> Messages <span class="ml-auto bg-purple-200 text-purple-800 text-xs py-1 px-2 rounded-full"><%= messages.length %></span>
                </button>
                <button
                    id="donations-tab-btn"
                    class="w-full text-left py-3 px-5 rounded-xl font-medium transition-all duration-200 flex items-center gap-3 text-gray-600 hover:bg-gray-50 hover:text-green-600"
                >
                    <span>💰</span> Donations <span class="ml-auto bg-green-200 text-green-800 text-xs py-1 px-2 rounded-full">₹<%= totalDonations.toFixed(2) %></span>
                </button>
            </nav>
            <div class="mt-auto pt-6 border-t border-gray-100">
                <form action="/admin/logout" method="POST">
                    <button type="submit" class="w-full bg-red-50 text-red-600 py-2 px-4 rounded-lg hover:bg-red-100 transition font-semibold text-sm">
                        Logout
                    </button>
                </form>
                <a href="/" class="block w-full mt-3 text-gray-400 hover:text-gray-600 text-xs text-center">
                    Go to Website
                </a>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="flex-1 p-6 md:p-10 overflow-y-auto">
            <header class="mb-8 flex justify-between items-center">
                <h1 id="overview-title" class="text-3xl font-bold text-gray-800 capitalize">Messages Overview</h1>
                <div class="text-sm text-gray-500 flex items-center gap-2">
                    Welcome back, Admin 👋
                    <span id="connection-status" class="px-2 py-1 rounded text-xs font-bold bg-gray-200 text-gray-500">Connecting...</span>
                </div>
            </header>

            <!-- Messages Section -->
            <div id="messages-content">
                <div class="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden">
                    <div class="overflow-x-auto">
                        <table class="w-full text-left border-collapse">
                            <thead class="bg-gray-50 text-gray-500 uppercase text-xs tracking-wider">
                                <tr>
                                    <th class="p-5 font-semibold">Role</th>
                                    <th class="p-5 font-semibold">Time</th>
                                    <th class="p-5 font-semibold">Message</th>
                                    <th class="p-5 font-semibold">Reply</th>
                                    <th class="p-5 font-semibold">Action</th>
                                </tr>
                            </thead>
                            <tbody id="messages-table-body" class="text-gray-700 text-sm divide-y divide-gray-100">
                                <% if (messages.length === 0) { %>
                                    <tr id="no-messages"><td colspan="5" class="p-8 text-center text-gray-400">No messages yet.</td></tr>
                                <% } else { %>
                                    <% messages.forEach(msg => { %>
                                        <tr id="msg-<%= msg.id %>" class="hover:bg-gray-50 transition-colors">
                                            <td class="p-5 font-medium">
                                                <span class="<%= msg.role === 'Sender' ? 'text-purple-600' : 'text-blue-600' %> font-bold">
                                                    <%= msg.role || 'Unknown' %>
                                                </span>
                                            </td>
                                            <td class="p-5 text-xs text-gray-500">
                                                <%= new Date(msg.timestamp).toLocaleString() %>
                                            </td>
                                            <td class="p-5 max-w-xs break-words"><%= msg.message %></td>
                                            <td class="p-5">
                                                <% if (msg.role === 'Sender') { %>
                                                    <div class="flex gap-2">
                                                        <input 
                                                            type="text" 
                                                            id="reply-input-<%= msg.id %>"
                                                            placeholder="Reply..." 
                                                            class="border rounded px-2 py-1 text-xs w-full"
                                                        />
                                                        <button 
                                                            onclick="sendReply('<%= msg.id %>')"
                                                            class="bg-blue-500 text-white px-3 py-1 rounded text-xs hover:bg-blue-600"
                                                        >
                                                            Send
                                                        </button>
                                                    </div>
                                                <% } %>
                                            </td>
                                            <td class="p-5">
                                                <button onclick="deleteMessage('<%= msg.id %>')" class="text-red-400 hover:text-red-600 p-2 rounded-full hover:bg-red-50 transition" title="Delete Message">
                                                    🗑️
                                                </button>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Donations Section (hidden by default) -->
            <div id="donations-content" style="display: none;">
                <div class="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden">
                    <div class="overflow-x-auto">
                        <table class="w-full text-left border-collapse">
                            <thead class="bg-gray-50 text-gray-500 uppercase text-xs tracking-wider">
                                <tr>
                                    <th class="p-5 font-semibold">Date</th>
                                    <th class="p-5 font-semibold">Amount</th>
                                    <th class="p-5 font-semibold">Payment ID</th>
                                    <th class="p-5 font-semibold">Status</th>
                                </tr>
                            </thead>
                            <tbody class="text-gray-700 text-sm divide-y divide-gray-100">
                                <% if (donations.length === 0) { %>
                                    <tr><td colspan="4" class="p-8 text-center text-gray-400">No donations recorded yet.</td></tr>
                                <% } else { %>
                                    <% donations.forEach(d => { %>
                                        <tr class="hover:bg-gray-50 transition-colors">
                                            <td class="p-5"><%= new Date(d.date).toLocaleString() %></td>
                                            <td class="p-5 font-bold text-green-600 text-base">₹<%= d.amount.toFixed(2) %></td>
                                            <td class="p-5 font-mono text-xs text-gray-500 bg-gray-50 rounded w-fit inline-block my-2 mx-5"><%= d.paymentId %></td>
                                            <td class="p-5">
                                                <span class="bg-green-100 text-green-700 py-1 px-3 rounded-full text-xs font-semibold shadow-sm">
                                                    <%= d.status %>
                                                </span>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <script>
        const messagesTabBtn = document.getElementById('messages-tab-btn');
        const donationsTabBtn = document.getElementById('donations-tab-btn');
        const messagesContent = document.getElementById('messages-content');
        const donationsContent = document.getElementById('donations-content');
        const overviewTitle = document.getElementById('overview-title');
        const socket = io();

        const statusSpan = document.getElementById('connection-status');

        socket.on("connect", () => {
            console.log("✅ Socket Connected:", socket.id);
            statusSpan.innerText = "🟢 Online";
            statusSpan.className = "px-2 py-1 rounded text-xs font-bold bg-green-100 text-green-700";
        });

        socket.on("disconnect", () => {
            console.log("❌ Socket Disconnected");
            statusSpan.innerText = "🔴 Offline";
            statusSpan.className = "px-2 py-1 rounded text-xs font-bold bg-red-100 text-red-700";
        });

        socket.on("connect_error", (err) => console.error("Socket Error:", err));

        function setActiveTab(tab) {
            if (tab === 'messages') {
                messagesContent.style.display = 'block';
                donationsContent.style.display = 'none';
                overviewTitle.textContent = 'Messages Overview';
                
                messagesTabBtn.className = 'w-full text-left py-3 px-5 rounded-xl font-medium transition-all duration-200 flex items-center gap-3 bg-purple-100 text-purple-700 shadow-inner';
                donationsTabBtn.className = 'w-full text-left py-3 px-5 rounded-xl font-medium transition-all duration-200 flex items-center gap-3 text-gray-600 hover:bg-gray-50 hover:text-green-600';
            } else if (tab === 'donations') {
                messagesContent.style.display = 'none';
                donationsContent.style.display = 'block';
                overviewTitle.textContent = 'Donations Overview';

                donationsTabBtn.className = 'w-full text-left py-3 px-5 rounded-xl font-medium transition-all duration-200 flex items-center gap-3 bg-green-100 text-green-700 shadow-inner';
                messagesTabBtn.className = 'w-full text-left py-3 px-5 rounded-xl font-medium transition-all duration-200 flex items-center gap-3 text-gray-600 hover:bg-gray-50 hover:text-purple-600';
            }
        }

        messagesTabBtn.addEventListener('click', () => setActiveTab('messages'));
        donationsTabBtn.addEventListener('click', () => setActiveTab('donations'));

        function sendReply(id) {
            const input = document.getElementById('reply-input-' + id);
            const message = input.value;
            if (!message) return;

            const replyData = {
                id: Date.now(),
                message: message,
                role: "Receiver", // Admin acts as Receiver
                timestamp: new Date().toISOString()
            };

            socket.emit("send_message", replyData);
            input.value = "";
            // addMessageRow(replyData); // Removed to prevent duplicates. Wait for server event.
        }

        function deleteMessage(id) {
            if (confirm("Delete this message?")) {
                socket.emit("delete_for_everyone", [Number(id)]);
                // removeMessageRow(id); // Removed. Wait for server event.
            }
        }

        socket.on("receive_message", (data) => {
            addMessageRow(data);
        });

        socket.on("delete_for_everyone", (ids) => {
            ids.forEach(id => removeMessageRow(id));
        });

        function addMessageRow(msg) {
            const tbody = document.getElementById('messages-table-body');
            const noMsg = document.getElementById('no-messages');
            if (noMsg) noMsg.remove();

            const tr = document.createElement('tr');
            tr.id = 'msg-' + msg.id;
            tr.className = 'hover:bg-gray-50 transition-colors';
            
            const roleColor = msg.role === 'Sender' ? 'text-purple-600' : 'text-blue-600';
            const replyHtml = msg.role === 'Sender' ? `
                <div class="flex gap-2">
                    <input type="text" id="reply-input-${msg.id}" placeholder="Reply..." class="border rounded px-2 py-1 text-xs w-full" />
                    <button onclick="sendReply('${msg.id}')" class="bg-blue-500 text-white px-3 py-1 rounded text-xs hover:bg-blue-600">Send</button>
                </div>
            ` : '';

            tr.innerHTML = `
                <td class="p-5 font-medium"><span class="${roleColor} font-bold">${msg.role || 'Unknown'}</span></td>
                <td class="p-5 text-xs text-gray-500">${new Date(msg.timestamp).toLocaleString()}</td>
                <td class="p-5 max-w-xs break-words">${msg.message}</td>
                <td class="p-5">${replyHtml}</td>
                <td class="p-5">
                    <button onclick="deleteMessage('${msg.id}')" class="text-red-400 hover:text-red-600 p-2 rounded-full hover:bg-red-50 transition" title="Delete Message">🗑️</button>
                </td>
            `;
            
            tbody.insertBefore(tr, tbody.firstChild);
        }

        function removeMessageRow(id) {
            const row = document.getElementById('msg-' + id);
            if (row) row.remove();
        }
    </script>
</body>
</html>